<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="CustomerCsvValidationResult">
        <property name="isSuccess" type="bool"/>
        <property name="error" type="string"/>
    </transfer>

    <transfer name="CustomerListImportResponse">
        <property name="customerList" type="CustomerList"/>
        <property name="errors" type="CustomerListImportError[]" singular="error"/>
        <property name="customerListImportRequest" type="CustomerListImportRequest"/>
        <property name="isSuccess" type="bool"/>
    </transfer>

    <transfer name="CustomerList">
        <property name="idCustomerList" type="int"/>
        <property name="name" type="string"/>
        <property name="createdAt" type="string"/>
        <property name="isActive" type="bool"/>
    </transfer>

    <transfer name="CustomerListImportError">
        <property name="customerImport" type="CustomerImport"/>
        <property name="message" type="string"/>
        <property name="parameters" type="string[]" singular="parameter"/>
    </transfer>

    <transfer name="CustomerListImportRequest">
        <property name="customerList" type="CustomerList"/>
        <property name="items" type="CustomerImport[]" singular="item"/>
    </transfer>

    <transfer name="CustomerImport">
        <property name="metaData" type="CustomerImportMetaData"/>
        <property name="company" type="Company"/>
        <property name="companyBusinessUnit" type="CompanyBusinessUnit"/>
        <property name="companyUnitAddress" type="CompanyUnitAddress"/>
        <property name="customer" type="Customer"/>
        <property name="companyUser" type="CompanyUser"/>
    </transfer>

    <transfer name="CustomerImportMetaData">
        <property name="identifier" type="string"/>
    </transfer>

    <transfer name="Company">
        <property name="isNew" type="bool"/>
        <property name="storeName" type="string"/>
    </transfer>

    <transfer name="CompanyBusinessUnit">
        <property name="parentCompanyBusinessUnitKey" type="string"/>
    </transfer>

    <transfer name="CompanyUnitAddress">
        <property name="state" type="string"/>
    </transfer>

</transfers>
